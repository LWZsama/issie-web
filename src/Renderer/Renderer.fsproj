    <Compile Include="Common/DrawHelpers.fs" />
    <Compile Include="Common/Helpers.fs" />
    <Compile Include="Common/TimeHelpers.fs" />
    <Compile Include="Common/WidthInferer.fs" />

	  <!-- UART -->
