<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RuntimeIdentifiers>win-x64;linux-x64</RuntimeIdentifiers>
    <RestoreConfigFile>$(MSBuildThisFileDirectory)../../Nuget.Config</RestoreConfigFile>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <DefineConstants>TRACE</DefineConstants>
  </PropertyGroup>
  <PropertyGroup>
    <RepositoryUrl>https://github.com/LWZsama/issie-web</RepositoryUrl>
  </PropertyGroup>
  <PropertyGroup>
      <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <DefineConstants>TRACE</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Fable.Browser.Css" Version="2.2" />
    <PackageReference Include="Fable.Browser.Dom" Version="2.18.1" />
    <PackageReference Include="Fable.Core" Version="3.7.1" />
    <PackageReference Include="Fable.Electron" Version="6.0" />
    <PackageReference Include="Fable.Elmish" Version="3.1" />
    <PackageReference Include="Fable.Elmish.Debugger" Version="3.3" />
    <PackageReference Include="Fable.Elmish.HMR" Version="5.2" />
    <PackageReference Include="Fable.Elmish.React" Version="3.0.1" />
    <PackageReference Include="Fable.Node" Version="1.2" />
    <PackageReference Include="Fable.Promise" Version="3.1.3" />
    <PackageReference Include="Fable.React" Version="8.0.1" />
    <PackageReference Include="Fable.SimpleJson" Version="3.24" />
    <PackageReference Include="Fulma" Version="2.16" />
    <PackageReference Include="Fulma.Extensions.Wikiki.Tooltip" Version="3.0" />
    <PackageReference Include="Thoth.Json" Version="7.0" />
    <PackageReference Include="Thoth.Json.Net" Version="11.0" />
  </ItemGroup>

  <ItemGroup>
